                    else:
                        tn.write(b'no shutdown\r\n')
                    time.sleep(0.1)
                    tn.read_very_eager()
                tn.write(b'end\r\n')
                time.sleep(0.3)
                tn.read_very_eager()
                tn.write(b'write memory\r\n')
                time.sleep(1)
                tn.read_very_eager()
                if device_name not in self.connections:

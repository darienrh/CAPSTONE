def apply_ospf_fixes(tn, fixes):
    try:
        clear_line_and_reset(tn)
        tn.write(b'configure terminal\r\n')
        time.sleep(0.3)
        tn.read_very_eager()
        for cmd in fixes:
            if cmd.startswith('#'):
                continue
            tn.write(cmd.encode('ascii') + b'\r\n')
            time.sleep(0.3)
            tn.read_very_eager()
        tn.write(b'end\r\n')
        time.sleep(0.3)
        tn.read_very_eager()

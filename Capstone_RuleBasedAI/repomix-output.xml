                time.sleep(0.2)
                tn.read_very_eager()
                is_eigrp = device_name.upper() in ['R1', 'R2', 'R3']
                is_ospf = device_name.upper() in ['R4', 'R5', 'R6']
                if is_eigrp:
                    tn.write(b'no router eigrp 1\r\n')
